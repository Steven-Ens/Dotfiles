# ~/.bashrc

# If not running interactively, don't do anything
[[ $- != *i* ]] && return

# Prompts 1 & 2
PS1='\[\e[1;38;5;150m\]\u \[\e[1;37m\]at \[\e[1;38;5;150m\]\h \[\e[1;37m\]in \[\e[1;38;5;139m\]\w \[\e[1;37m\]\$ \[\e[0;37m\]'
PS2='\[\e[1;37m\]\$> \[\e[0;37m\]'

# Auto vi keybindings for bash
set -o vi

# Set vim as the default editor
export EDITOR=vim

# Update directory colours to blue (di) 
LSCOLORS="Gx"
export LSCOLORS
# Add foundry commands
export PATH="$PATH:/Users/steve/.foundry/bin"

# Reset CTL-l to clear screen after vi keys set
bind -m vi-insert "\C-l":clear-screen

# Aliases
# Modify ls 
alias ls='ls -ahlG'

# Last directory
alias ..='cd ..' 
alias ...='cd ../..'

# Directory shortcuts
alias h='cd ~' 
alias d='cd ~/Downloads' 
alias r='cd ~/Repositories' 
alias s='cd ~/Repositories/solidity-sol79-steven'

# Open new terminal in same directory as current terminal
function cd()
{
	builtin cd "$*"
	pwd > ~/.lastdir
}
if [ -e ~/.lastdir ]; then
	cd "$(cat ~/.lastdir)"
fi

# Open new terminal in ~ once terminal closed
trap "echo /Users/steve > ~/.lastdir" EXIT

export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"  # This loads nvm
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"  # This loads nvm bash_completion
