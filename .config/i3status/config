# ~/.config/i3status/config

# It is important that this file is edited as UTF-8.
# The following line should contain a sharp s:
# ß

general {
        colors = true
        interval = 1
}

order += "path_exists VPN"
order += "wireless wlan0"
order += "ethernet eth0"
order += "disk /mnt/usb"
order += "disk /"
order += "memory"
order += "cpu_usage"
order += "cpu_temperature 0"
order += "volume master"
order += "battery 0"
order += "time"

path_exists VPN {
        path = "/proc/sys/net/ipv4/conf/tun0"
        format = " VPN "
}

wireless wlan0 {
        format_up = " W: %ip (%quality @ %essid )"
        format_down = " W: DOWN "
}

ethernet eth0 {
        format_up = " E: %ip " 
        format_down = " E: DOWN "
}

disk "/mnt/usb" {
        format = " F: %percentage_used USED of %total "
		format_not_mounted = " F: NONE "
		threshold_type = "percentage_free"
    	low_threshold = "20"
    	format_below_threshold = " F: %percentage_free FREE "
}

disk "/" {
        format = " S: %percentage_used USED of %total "
		threshold_type = "percentage_free"
		low_threshold = "20"
    	format_below_threshold = " S: %percentage_free FREE "
}

memory {
        format = " M: %percentage_used USED of %total "
        threshold_degraded = "60%"
    	threshold_critical = "10%"
		format_degraded = " M: %percentage_free FREE "
}

cpu_usage {
    	format = " P: %usage "
    	degraded_threshold = "60"
    	max_threshold = "90"
}

cpu_temperature 0 {
    	format = " P: %degreesC "
    	path = "/sys/class/hwmon/hwmon*/temp1_input"
    	max_threshold = "60"
}

volume master {
        format = " V: %volume "
        format_muted = " V: MUTED (%volume) "
}

battery 0 {
        format = " B: %percentage "
		min_width = 100
		align = "center"
		format_percentage = "%0.00f%s"
        format_down = " B: NONE "
        path = "/sys/class/power_supply/BAT1/uevent"
        last_full_capacity = true
		threshold_type = "percentage"
        low_threshold = "20"
}

time {
        format = " %H:%M %m-%d-%y "
}
