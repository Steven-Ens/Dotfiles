# ~/.config/i3/config

# Autostart programs in specific workspaces
exec --no-startup-id i3-msg "workspace 1; exec firefox; workspace 2; exec kitty; workspace 2" 

# brightnessctl keyboard keys
bindsym XF86MonBrightnessUp exec --no-startup-id brightnessctl set +10%
bindsym XF86MonBrightnessDown exec --no-startup-id brightnessctl set 10%-

# pipewire keyboard keys
set $refresh_i3status killall -SIGUSR1 i3status
bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +2% && $refresh_i3status
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -2% && $refresh_i3status
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle && $refresh_i3status

# Program launcher
bindsym Mod1+m mode Launcher
mode Launcher {
    bindsym f exec firefox ; mode "default"
    bindsym Escape mode "default" 
}

# Font options for window titles
font pango:DejaVu Sans Mono 16

# Start a terminal window
bindsym Mod1+Return exec kitty

# Kill the focused window
bindsym Mod1+BackSpace kill 

# Movement keys
set $up k
set $down j
set $left h
set $right l

# Resize window with vim keys a row above 'yuio' 
bindsym Mod1+y resize shrink width 10 px or 10 ppt
bindsym Mod1+u resize shrink height 10 px or 10 ppt
bindsym Mod1+i resize grow height 10 px or 10 ppt
bindsym Mod1+o resize grow width 10 px or 10 ppt

# Change focus
bindsym Mod1+$left focus left
bindsym Mod1+$down focus down
bindsym Mod1+$up focus up
bindsym Mod1+$right focus right

# Move focused window
bindsym Mod1+Shift+$left move left
bindsym Mod1+Shift+$down move down
bindsym Mod1+Shift+$up move up
bindsym Mod1+Shift+$right move right

# Open terminal to the right
bindsym Mod1+r split h ; exec kitty 

# Open terminal below
bindsym Mod1+d split v ; exec kitty

# Enter fullscreen mode for the focused container
bindsym Mod1+f fullscreen toggle

# Focus the parent container
bindsym Mod1+p focus parent  

# Define variable names for default workspaces 
set $ws1 "1" 
set $ws2 "2"
set $ws3 "3" 
set $ws4 "4"
set $ws5 "5" 
set $ws6 "6"
set $ws7 "7" 
set $ws8 "8"
set $ws9 "9" 

# Switch to a workspace
bindsym Mod1+1 workspace number $ws1
bindsym Mod1+2 workspace number $ws2
bindsym Mod1+3 workspace number $ws3
bindsym Mod1+4 workspace number $ws4
bindsym Mod1+5 workspace number $ws5
bindsym Mod1+6 workspace number $ws6
bindsym Mod1+7 workspace number $ws7
bindsym Mod1+8 workspace number $ws8
bindsym Mod1+9 workspace number $ws9

# Move the focused container to a workspace
bindsym Mod1+Shift+1 move container to workspace number $ws1
bindsym Mod1+Shift+2 move container to workspace number $ws2
bindsym Mod1+Shift+3 move container to workspace number $ws3
bindsym Mod1+Shift+4 move container to workspace number $ws4
bindsym Mod1+Shift+5 move container to workspace number $ws5
bindsym Mod1+Shift+6 move container to workspace number $ws6
bindsym Mod1+Shift+7 move container to workspace number $ws7
bindsym Mod1+Shift+8 move container to workspace number $ws8
bindsym Mod1+Shift+9 move container to workspace number $ws9

# Lock the computer
bindsym Mod1+space exec --no-startup-id i3lock -f -c 000000

# Restart i3 preserving the session
bindsym Mod1+Shift+r restart

# Exit i3 and log out of your X session
bindsym Mod1+Shift+e exec "i3-nagbar -t warning -m 'Exit?' -B ' YES ' 'i3-msg exit'"

# Start i3bar to display the i3status bar 
bar {
    status_command i3status
    position top
    font pango: DejaVu Sans Mono 16

    colors {
        background #3B4252
    }
}
